<Window x:Class="CharacterInventory.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CharacterInventory.Wpf.ViewModels"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        Title="Inventory" Width="900" Height="550"
        Background="#1E1E1E">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>


    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <GroupBox Header="Inventory" Foreground="White" Grid.Column="0" Margin="0,0,12,0">
            <DockPanel LastChildFill="True">

                <ItemsControl ItemsSource="{Binding Slots}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="12"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Padding="0"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Click="Slot_Click"
                                    PreviewMouseLeftButtonDown="Slot_PreviewMouseLeftButtonDown"
                                    FocusVisualStyle="{x:Null}"
                                    Focusable="False"
                                    BorderBrush="{x:Null}">

                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Button.Template>

                                <Border Width="75"
                                        Height="75"
                                        Margin="6"
                                        CornerRadius="8"
                                        BorderThickness="4"
                                        Padding="6">


                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="#4A4A4A"/>
                                            <Setter Property="Background" Value="#2A2A2A"/>

                                            <Style.Triggers>

                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#E6C36A"/>
                                                    <Setter Property="Background" Value="#333333"/>
                                                </DataTrigger>

                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="#E6C36A"/>
                                                    <Setter Property="Background" Value="#4A4A4A"/>
                                                </Trigger>

                                                <DataTrigger Binding="{Binding HasItem}" Value="False">
                                                    <Setter Property="Opacity" Value="0.85"/>
                                                </DataTrigger>

                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>

                                        <Image Source="{Binding IconPath}"
                                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                   Visibility="{Binding HasItem, Converter={StaticResource BoolToVis}}"/>

                                        <Border HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Background="#B0000000"
                                                CornerRadius="6"
                                                Padding="4,1"
                                                Visibility="{Binding ShowCount, Converter={StaticResource BoolToVis}}">

                                            <TextBlock Text="{Binding Count, StringFormat=x{0}}"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       FontSize="12"/>

                                        </Border>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </GroupBox>

        <GroupBox Header="Description" Grid.Column="1" Foreground="White">
            <StackPanel Margin="10">

                <Grid Margin="0,0,0,10" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ItemsControl Grid.Column="0" ItemsSource="{Binding EquipLeftSlots}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Padding="0"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        Click="EquipSlot_Click"
                                        MouseDoubleClick="EquipSlot_DoubleClick"
                                        Focusable="False"
                                        FocusVisualStyle="{x:Null}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Button.Template>

                                    <Border Width="54" Height="54" Margin="6"
                                            CornerRadius="8"
                                            BorderThickness="3">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="#4A4A4A"/>
                                                <Setter Property="Background" Value="#2A2A2A"/>

                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#E6C36A"/>
                                                        <Setter Property="Background" Value="#333333"/>
                                                    </DataTrigger>

                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#E6C36A"/>
                                                        <Setter Property="Background" Value="#4A4A4A"/>
                                                    </Trigger>

                                                    <DataTrigger Binding="{Binding HasItem}" Value="False">
                                                        <Setter Property="Opacity" Value="0.85"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Image Source="{Binding IconPath}"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                                               Visibility="{Binding HasItem, Converter={StaticResource BoolToVis}}"/>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Grid.Column="1"
                            Width="140" Height="140"
                            CornerRadius="12"
                            Background="#FFD3D3D3"
                            BorderBrush="#4A4A4A"
                            BorderThickness="2"
                            Margin="6">
                        <Image Width="128" Height="128"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                               gif:ImageBehavior.AnimatedSource="{Binding SelectedCharacter.CharacterImage}" />
                    </Border>

                    <ItemsControl Grid.Column="2" ItemsSource="{Binding EquipRightSlots}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Padding="0"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        Click="EquipSlot_Click"
                                        MouseDoubleClick="EquipSlot_DoubleClick"
                                        Focusable="False"
                                        FocusVisualStyle="{x:Null}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Button.Template>

                                    <Border Width="54" Height="54" Margin="6"
                                            CornerRadius="8"
                                            BorderThickness="3">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="#4A4A4A"/>
                                                <Setter Property="Background" Value="#2A2A2A"/>

                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#E6C36A"/>
                                                        <Setter Property="Background" Value="#333333"/>
                                                    </DataTrigger>

                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#E6C36A"/>
                                                        <Setter Property="Background" Value="#4A4A4A"/>
                                                    </Trigger>

                                                    <DataTrigger Binding="{Binding HasItem}" Value="False">
                                                        <Setter Property="Opacity" Value="0.85"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Image Source="{Binding IconPath}"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                                               Visibility="{Binding HasItem, Converter={StaticResource BoolToVis}}"/>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <TextBlock Text="{Binding SelectedCharacter.Name}"
                           FontSize="21"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>

                <TextBlock Text="{Binding SelectedCharacter.Role}"
                           FontSize="12"
                           Foreground="#BFBFBF"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Character Stats"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,8,0,6"/>

                <StackPanel>
                    <TextBlock Foreground="#CCCCCC" Text="{Binding TotalHealth, StringFormat=HP: {0}}"/>
                    <TextBlock Foreground="#CCCCCC" Text="{Binding TotalStrength, StringFormat=STRENGTH: {0}}"/>
                    <TextBlock Foreground="#CCCCCC" Text="{Binding TotalStamina, StringFormat=STAMINA: {0}}"/>
                    <TextBlock Foreground="#CCCCCC" Text="{Binding TotalMagicDefense, StringFormat=MAGIC DEFENSE: {0}}"/>
                </StackPanel>

                <Separator Margin="0,12,0,12" Background="#444"/>

                <TextBlock Text="Item Details"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,6"/>

                <Grid>
                    <TextBlock Text="Select an item…"
                               Foreground="#888"
                               FontStyle="Italic">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasDisplayItem}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel Visibility="{Binding HasDisplayItem, Converter={StaticResource BoolToVis}}">
                        <TextBlock FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Text="{Binding DisplayItem.Name}"/>

                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#CCCCCC"
                                   Text="{Binding DisplayItem.Type, StringFormat=Type: {0}}"/>

                        <TextBlock Foreground="#CCCCCC"
                                   Text="{Binding DisplayItem.Count, StringFormat=Count: {0}}"/>

                        <TextBlock Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="White"
                                   Text="{Binding DisplayItem.Description}" />

                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#CCCCCC"
                                   Text="{Binding DisplayItem.StatsText}"/>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </GroupBox>
    </Grid>
</Window>
